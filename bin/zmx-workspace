#!/usr/bin/env bash
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zmx-sessionizer"
CONFIG_FILE="$CONFIG_DIR/zmx-sessionizer.conf"
WORKSPACE_DIR="$CONFIG_DIR/workspaces"
mkdir -p "$WORKSPACE_DIR"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
[[ -n "$ZMX_SEARCH_PATHS" ]] || ZMX_SEARCH_PATHS=(~/Development)

_fzf() {
    fzf --height=50% --border=rounded --reverse "$@"
}

_zmx_sessions() {
    zmx list 2>/dev/null | while IFS=$'\t' read -r name _pid _clients _created _dir _rest; do
        [[ "$_rest" == *"err="* ]] && continue
        name=${name#"${name%%[a-zA-Z_]*}"}
        echo "${name#name=}"
    done
}

_list_projects() {
    for f in "$WORKSPACE_DIR"/*.conf; do
        [[ -f "$f" ]] && basename "$f" .conf
    done
}

_load_project() {
    local conf="$WORKSPACE_DIR/$1.conf"
    [[ ! -f "$conf" ]] && { echo "project '$1' not found. run: zmx-workspace new" >&2; return 1; }
    unset ZMX_DIR ZMX_SESSIONS
    source "$conf"
}

_pick_project() {
    local prompt="${1:-project> }"
    local count
    count=$(_list_projects | wc -l | tr -d ' ')
    [[ "$count" -eq 0 ]] && { echo "no projects. run: zmx-workspace new" >&2; return 1; }
    [[ "$count" -eq 1 ]] && { _list_projects; return 0; }
    _list_projects | _fzf --prompt="$prompt"
}

cmd_new() {
    printf "project name: "; read -r project
    [[ -z "$project" ]] && return 1
    [[ "$project" =~ [^a-zA-Z0-9_-] ]] && {
        echo "project name: only letters, digits, hyphens, underscores"
        return 1
    }
    [[ -f "$WORKSPACE_DIR/$project.conf" ]] && {
        echo "project '$project' already exists. use: zmx-workspace edit $project"
        return 1
    }

    local dir
    printf "directory (empty for fzf picker) [%s]: " "$PWD"; read -r dir
    if [[ -z "$dir" ]]; then
        dir=$(
            for p in "${ZMX_SEARCH_PATHS[@]}"; do
                if [[ "$p" =~ ^([^:]+):([0-9]+)$ ]]; then
                    fd --type d --max-depth "${BASH_REMATCH[2]}" . "${BASH_REMATCH[1]}" 2>/dev/null
                else
                    fd --type d --max-depth "${ZMX_MAX_DEPTH:-1}" . "$p" 2>/dev/null
                fi
            done | _fzf --prompt="project dir> "
        )
        [[ -z "$dir" ]] && { echo "no directory selected"; return 1; }
    else
        dir="${dir/#\~/$HOME}"
        [[ ! -d "$dir" ]] && { echo "directory '$dir' does not exist"; return 1; }
    fi

    local sessions=()
    echo "sessions -- format: name:command  (bare shell: name:)  empty line to finish"
    echo "  e.g.:"
    echo "    editor:nvim ."
    echo "    server:npm start"
    echo "    shell:"
    while true; do
        printf "  session> "; read -r entry
        [[ -z "$entry" ]] && break
        if [[ "$entry" != *:* ]]; then
            echo "  missing colon -- use name:command or name: for bare shell"
            continue
        fi
        local sess_name="${entry%%:*}"
        if [[ -z "$sess_name" ]]; then
            echo "  session name cannot be empty"
            continue
        fi
        if [[ "$sess_name" =~ [^a-zA-Z0-9_-] ]]; then
            echo "  session name '$sess_name': only letters, digits, hyphens, underscores"
            continue
        fi
        sessions+=("$entry")
    done

    local conf="$WORKSPACE_DIR/$project.conf"
    {
        printf "ZMX_DIR=%q\n" "$dir"
        echo "ZMX_SESSIONS=("
        for s in "${sessions[@]}"; do
            printf '    %q\n' "$s"
        done
        echo ")"
    } > "$conf"

    echo "created: $conf"
    printf "open sessions now? [Y/n]: "; read -r yn
    [[ "${yn:-Y}" =~ ^[Yy]$ ]] && cmd_open "$project"
}

cmd_edit() {
    local project="$1"
    [[ -z "$project" ]] && project=$(_pick_project "edit project> ") || true
    [[ -z "$project" ]] && return 0
    local conf="$WORKSPACE_DIR/$project.conf"
    [[ ! -f "$conf" ]] && { echo "project '$project' not found"; return 1; }
    ${EDITOR:-nvim} "$conf"
}

cmd_open() {
    local project="$1"
    [[ -z "$project" ]] && project=$(_pick_project "open project> ") || true
    [[ -z "$project" ]] && return 0

    _load_project "$project" || return 1

    local active_sessions
    active_sessions=$(_zmx_sessions)

    if [[ ${#ZMX_SESSIONS[@]} -eq 0 ]]; then
        echo "no sessions configured for '$project'. edit with: zmx-workspace edit $project"
        return 0
    fi

    cd "$ZMX_DIR" || return 1

    for entry in "${ZMX_SESSIONS[@]}"; do
        local suffix="${entry%%:*}"
        local cmd="${entry#*:}"
        local session="${project}-${suffix}"

        if printf '%s\n' "$active_sessions" | grep -qFx "$session"; then
            echo "  [exists]  $session"
        else
            local ok=0
            if [[ -n "$cmd" ]]; then
                ZMX_START_DIR="$ZMX_DIR" ZMX_SESSION_CMD="$cmd" \
                    zmx run "$session" -d "${SHELL:-zsh}" -c 'cd "$ZMX_START_DIR" && clear && eval "$ZMX_SESSION_CMD"; exec "$SHELL"' && ok=1
            else
                ZMX_START_DIR="$ZMX_DIR" \
                    zmx run "$session" -d "${SHELL:-zsh}" -c 'cd "$ZMX_START_DIR" && clear' \
                    && zmx wait "$session" \
                    && zmx send "$session" "$(printf 'clear\r')" \
                    && ok=1
            fi
            [[ $ok -eq 1 ]] && echo "  [created] $session" || echo "  [failed]  $session"
        fi
    done

    echo ""
    echo "attach: zmx-workspace attach $project"
}

cmd_attach() {
    local project="$1"
    [[ -z "$project" ]] && project=$(_pick_project "project> ") || true
    [[ -z "$project" ]] && return 0

    _load_project "$project" || return 1

    if [[ ${#ZMX_SESSIONS[@]} -eq 0 ]]; then
        echo "no sessions configured for '$project'. edit with: zmx-workspace edit $project"
        return 1
    fi

    local active_sessions
    active_sessions=$(_zmx_sessions)

    local display_list=()
    for entry in "${ZMX_SESSIONS[@]}"; do
        local suffix="${entry%%:*}"
        local session="${project}-${suffix}"
        if printf '%s\n' "$active_sessions" | grep -qFx "$session"; then
            display_list+=("$session (active)")
        else
            display_list+=("$session")
        fi
    done

    local selected
    if [[ ${#display_list[@]} -eq 1 ]]; then
        selected="${display_list[0]}"
    else
        selected=$(printf '%s\n' "${display_list[@]}" | _fzf --prompt="$project> ")
    fi
    [[ -z "$selected" ]] && return 0

    local session="${selected% (active)}"

    if printf '%s\n' "$active_sessions" | grep -qFx "$session"; then
        printf '\e]0;%s\a' "$session"
        exec zmx attach "$session"
    fi

    # first attach: create session with proper PTY via zmx attach
    local suffix="${session#${project}-}"
    local cmd=""
    for entry in "${ZMX_SESSIONS[@]}"; do
        [[ "${entry%%:*}" == "$suffix" ]] && { cmd="${entry#*:}"; break; }
    done

    printf '\e]0;%s\a' "$session"
    if [[ -n "$cmd" ]]; then
        ZMX_START_DIR="$ZMX_DIR" ZMX_SESSION_CMD="$cmd" \
            exec zmx attach "$session" "${SHELL:-zsh}" -c 'cd "$ZMX_START_DIR" && eval "$ZMX_SESSION_CMD" && exec "$SHELL"'
    else
        ZMX_START_DIR="$ZMX_DIR" \
            exec zmx attach "$session" "${SHELL:-zsh}" -c 'cd "$ZMX_START_DIR" && exec "$SHELL"'
    fi
}

cmd_list() {
    if ! _list_projects | grep -q .; then
        echo "no projects. run: zmx-workspace new"
        return 0
    fi
    local active_sessions
    active_sessions=$(_zmx_sessions)

    _list_projects | while read -r project; do
        _load_project "$project" 2>/dev/null || continue
        local active=0 total=0
        for entry in "${ZMX_SESSIONS[@]}"; do
            local suffix="${entry%%:*}"
            total=$((total+1))
            printf '%s\n' "$active_sessions" | grep -qFx "${project}-${suffix}" && active=$((active+1))
        done
        printf "  %-20s  %d/%d sessions  %s\n" "$project" "$active" "$total" "$ZMX_DIR"
    done
}

cmd_kill() {
    local project="$1"
    [[ -z "$project" ]] && project=$(_pick_project "kill project> ") || true
    [[ -z "$project" ]] && return 0

    _load_project "$project" || return 1

    for entry in "${ZMX_SESSIONS[@]}"; do
        local suffix="${entry%%:*}"
        local session="${project}-${suffix}"
        zmx kill "$session" 2>/dev/null && echo "  [killed] $session"
    done
}

cmd_delete() {
    local project="$1"
    [[ -z "$project" ]] && project=$(_pick_project "delete project> ") || true
    [[ -z "$project" ]] && return 0

    local conf="$WORKSPACE_DIR/$project.conf"
    [[ ! -f "$conf" ]] && { echo "project '$project' not found"; return 1; }

    printf "delete project '%s' and kill all its sessions? [y/N]: " "$project"
    read -r yn
    [[ "${yn}" =~ ^[Yy]$ ]] || return 0

    _load_project "$project" || return 1
    for entry in "${ZMX_SESSIONS[@]}"; do
        local suffix="${entry%%:*}"
        zmx kill "${project}-${suffix}" 2>/dev/null && echo "  [killed] ${project}-${suffix}"
    done

    rm "$conf" && echo "  [deleted] $conf"
}

cmd_kill_session() {
    local sessions
    sessions=$(_zmx_sessions)
    if [[ -z "$sessions" ]]; then
        echo "no active zmx sessions" >&2
        return 1
    fi
    local session
    session=$(printf '%s\n' "$sessions" | _fzf --prompt="kill session> ")
    [[ -z "$session" ]] && return 0
    zmx kill "$session" 2>/dev/null && echo "[killed] $session"
}

case "${1:-help}" in
    new|n)           cmd_new ;;
    edit|e)          cmd_edit "$2" ;;
    open|o)          cmd_open "$2" ;;
    attach|a)        cmd_attach "$2" ;;
    list|l|ls)       cmd_list ;;
    kill|k)          cmd_kill "$2" ;;
    kill-session|ks) cmd_kill_session ;;
    delete|d)        cmd_delete "$2" ;;
    *)
        echo "zmx-workspace <command> [project]"
        echo "  new              interactive project setup"
        echo "  edit   [project] edit project config in \$EDITOR"
        echo "  open   [project] create all sessions for project"
        echo "  attach [project] fzf attach to a project session"
        echo "  list             list all projects with session status"
        echo "  kill   [project] kill all sessions for project"
        echo "  kill-session     fzf pick and kill any session"
        echo "  delete [project] kill all sessions and remove project config"
        ;;
esac
