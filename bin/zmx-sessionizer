#!/usr/bin/env bash
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zmx-sessionizer"
CONFIG_FILE="$CONFIG_DIR/zmx-sessionizer.conf"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
[[ -n "$TS_SEARCH_PATHS" ]] || TS_SEARCH_PATHS=(~/Development)
[[ ${#TS_EXTRA_SEARCH_PATHS[@]} -gt 0 ]] && TS_SEARCH_PATHS+=("${TS_EXTRA_SEARCH_PATHS[@]}")

_list_sessions() {
    zmx list 2>/dev/null | while IFS=$'\t' read -r name pid clients _created dir _rest; do
        [[ "$_rest" == *"ended="* ]] && continue
        name=${name#"${name%%[a-zA-Z_]*}"}
        name=${name#name=}
        pid=${pid#pid=}
        clients=${clients#clients=}
        dir=${dir#start_dir=}
        printf "[ZMX] %-20s  pid:%-8s  clients:%-2s  %s\n" "$name" "$pid" "$clients" "$dir"
    done
}

_list_dirs() {
    local path depth
    for entry in "${TS_SEARCH_PATHS[@]}"; do
        if [[ "$entry" =~ ^([^:]+):([0-9]+)$ ]]; then
            path="${BASH_REMATCH[1]}"; depth="${BASH_REMATCH[2]}"
        else
            path="$entry"; depth="${TS_MAX_DEPTH:-1}"
        fi
        [[ -d "$path" ]] && fd --type d --max-depth "$depth" . "$path"
    done
}

_pick() {
    fzf \
        --print-query \
        --expect=ctrl-n \
        --prompt="session> " \
        --height=80% \
        --reverse \
        --border=rounded \
        --header="Enter: select  Ctrl-N: new session  Esc: plain shell"
}

if [[ -n "$1" ]]; then
    selected="$1"
    rc=0
    query=""
    key=""
else
    output=$({ printf '[here] %s\n' "$PWD"; _list_sessions; _list_dirs; } | _pick)
    rc=$?
    query=$(printf '%s\n' "$output" | sed -n '1p')
    key=$(printf '%s\n' "$output" | sed -n '2p')
    selected=$(printf '%s\n' "$output" | sed -n '3p')
fi

session_name=""
start_dir=""

if [[ "$key" == "ctrl-n" ]]; then
    [[ -z "$query" ]] && exec "${SHELL:-zsh}"
    session_name="$query"
elif [[ "$selected" =~ ^\[ZMX\]\ ([^[:space:]]+) ]]; then
    exec zmx attach "${BASH_REMATCH[1]}"
elif [[ "$selected" =~ ^\[here\]\ (.+)$ ]]; then
    start_dir="${BASH_REMATCH[1]}"
    session_name=$(basename "$start_dir" | tr '. ' '__')
elif [[ $rc -eq 0 && -n "$selected" ]]; then
    start_dir="$selected"
    session_name=$(basename "$selected" | tr '. ' '__')
elif [[ $rc -eq 0 && -n "$query" ]]; then
    session_name="$query"
else
    exec "${SHELL:-zsh}"
fi

if [[ -n "$start_dir" ]]; then
    ZMX_START_DIR="$start_dir" exec zmx attach "$session_name" "${SHELL:-zsh}" -c 'cd "$ZMX_START_DIR" && exec "$SHELL"'
else
    exec zmx attach "$session_name" "${SHELL:-zsh}" -c 'exec "$SHELL"'
fi
